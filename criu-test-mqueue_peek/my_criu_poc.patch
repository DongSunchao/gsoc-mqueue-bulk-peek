+                printf(">>> [GSoC PoC] Payload Preview: '%s'\n", tmp_payload);
+
+                raw_size = sizeof(struct mq_peek_msg_hdr) + hdr->chunk_len;
+                offset += ALIGN8(raw_size);
+            }
+        } else {
+            perror(">>> [GSoC PoC] ioctl failed");
+        }
+        close(mq_fd);
+    } else {
