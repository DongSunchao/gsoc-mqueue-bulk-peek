+	/* ================= GSOC HACK TEST ================= */
+    
+    #ifndef ALIGN8
+    #define ALIGN8(x) (((x) + 7) & ~(size_t)7)
+    #endif
+    
+    size_t offset = 0;
+    char peek_buf[16000];
+    struct mq_bulk_peek_args args = {0};
+    size_t raw_size = 0;
+    int mq_fd = open("/dev/mqueue/test_queue", O_RDONLY); 
+	uint32_t print_len;
+	char tmp_payload[128] = {0};
+
+    printf("test:3-20-3\n");
+    printf(">>> [GSoC PoC] Attempting to peek POSIX mqueue directly from CRIU...\n");
+
+    if (mq_fd >= 0) {
+        
+        args.max_count = 10;
+        args.buf_ptr = (uint64_t)(unsigned long)peek_buf;
+        args.buf_size = sizeof(peek_buf);
+
+        if (ioctl(mq_fd, MQ_IOC_BULK_PEEK, &args) == 0) {
+            printf(">>> [GSoC PoC] SUCCESS! CRIU peeked %u messages/chunks!\n", args.out_count);
+            
+            for (uint32_t i = 0; i < args.out_count; i++) {
+                struct mq_peek_msg_hdr *hdr = (struct mq_peek_msg_hdr *)(peek_buf + offset);
+
+                print_len = hdr->chunk_len < 50 ? hdr->chunk_len : 50;
+                memset(tmp_payload, 0, sizeof(tmp_payload));
+                memcpy(tmp_payload, hdr->payload, print_len);
+                
+                if (hdr->chunk_len > 50)
+                    strcat(tmp_payload, " ... [TRUNCATED]");
+
+                printf(">>> [GSoC PoC] Msg %u | Prio: %u | TotalLength: %u | ChunkLength: %u | Flags: 0x%x\n", 
