From 16ea1075b639c14311b38042828bc36a8c81ab41 Mon Sep 17 00:00:00 2001
From: dong sunchao <dongsunchao@gmail.com>
Date: Thu, 26 Mar 2026 22:23:15 +1100
Subject: [PATCH 1/3] images: add POSIX mqueue protobuf definitions

Define the image format needed to checkpoint/restore POSIX message queue
file descriptors.

- Add posix-mqueue.proto with ipcns_pmq_data_entry (queue attributes,
  repeated message entries, flags, fown) and posix_mqueue_msg_entry
  (priority, length, payload bytes).
- Extend file_entry in fdinfo.proto with a new fd_types value PQEFD (21)
  and an optional ipcns_pmq_data_entry field pqmfd.
- Register the new image type (IPCNS_PMQ_DATA) throughout the image
  infrastructure: magic number, image-desc template, protobuf descriptor
  enum and include.
---
 criu/image-desc.c            |  1 +
 criu/include/image-desc.h    |  1 +
 criu/include/magic.h         |  1 +
 criu/include/protobuf-desc.h |  1 +
 criu/protobuf-desc.c         |  1 +
 images/Makefile              |  1 +
 images/fdinfo.proto          |  3 +++
 images/posix-mqueue.proto    | 23 +++++++++++++++++++++++
 8 files changed, 32 insertions(+)
 create mode 100644 images/posix-mqueue.proto

diff --git a/criu/image-desc.c b/criu/image-desc.c
index c68ea04d7..eef12c8a2 100644
--- a/criu/image-desc.c
+++ b/criu/image-desc.c
@@ -63,6 +63,7 @@ struct cr_fd_desc_tmpl imgset_template[CR_FD_MAX] = {
 	FD_ENTRY_F(IPCNS_SHM,	"ipcns-shm-%u", O_NOBUF), /* writes segments of data */
 	FD_ENTRY(IPCNS_MSG,	"ipcns-msg-%u"),
 	FD_ENTRY(IPCNS_SEM,	"ipcns-sem-%u"),
+	FD_ENTRY(IPCNS_PMQ_DATA, "ipcns-pmq-%u"),
 	FD_ENTRY(FS,		"fs-%u"),
 	FD_ENTRY(REMAP_FPATH,	"remap-fpath"),
 	FD_ENTRY_F(GHOST_FILE,	"ghost-file-%x", O_NOBUF),
diff --git a/criu/include/image-desc.h b/criu/include/image-desc.h
index 79e1ac111..9ba928bf6 100644
--- a/criu/include/image-desc.h
+++ b/criu/include/image-desc.h
@@ -34,6 +34,7 @@ enum {
 	CR_FD_IPCNS_SHM,
 	CR_FD_IPCNS_MSG,
 	CR_FD_IPCNS_SEM,
+	CR_FD_IPCNS_PMQ_DATA,
 	_CR_FD_IPCNS_TO,
 
 	_CR_FD_NETNS_FROM,
diff --git a/criu/include/magic.h b/criu/include/magic.h
index 6f0aff26d..09f942255 100644
--- a/criu/include/magic.h
+++ b/criu/include/magic.h
@@ -58,6 +58,7 @@
 #define IPCNS_SHM_MAGIC	     0x46283044 /* Odessa */
 #define IPCNS_MSG_MAGIC	     0x55453737 /* Moscow */
 #define IPCNS_SEM_MAGIC	     0x59573019 /* St. Petersburg */
+#define IPCNS_PMQ_DATA_MAGIC    0x504d5131
 #define REG_FILES_MAGIC	     0x50363636 /* Belgorod */
 #define EXT_FILES_MAGIC	     0x59255641 /* Usolye */
 #define FS_MAGIC	     0x51403912 /* Voronezh */
diff --git a/criu/include/protobuf-desc.h b/criu/include/protobuf-desc.h
index c4241be55..ba70eb5bb 100644
--- a/criu/include/protobuf-desc.h
+++ b/criu/include/protobuf-desc.h
@@ -20,6 +20,7 @@ enum {
 	PB_IPC_VAR,
 	PB_IPC_SHM,
 	PB_IPC_SEM,
+	PB_IPCNS_PMQ_DATA,
 	PB_MNT,
 	PB_PSTREE,
 	PB_GHOST_FILE,
diff --git a/criu/protobuf-desc.c b/criu/protobuf-desc.c
index e0dbfccc2..dd85ec1cd 100644
--- a/criu/protobuf-desc.c
+++ b/criu/protobuf-desc.c
@@ -43,6 +43,7 @@
 #include "images/ipc-shm.pb-c.h"
 #include "images/ipc-msg.pb-c.h"
 #include "images/ipc-sem.pb-c.h"
+#include "images/posix-mqueue.pb-c.h"
 #include "images/fs.pb-c.h"
 #include "images/remap-file-path.pb-c.h"
 #include "images/ghost-file.pb-c.h"
diff --git a/images/Makefile b/images/Makefile
index 2c33152e9..862487925 100644
--- a/images/Makefile
+++ b/images/Makefile
@@ -74,6 +74,7 @@ proto-obj-y	+= bpfmap-data.o
 proto-obj-y	+= apparmor.o
 proto-obj-y	+= rseq.o
 proto-obj-y	+= pidfd.o
+proto-obj-y	+= posix-mqueue.o
 
 CFLAGS		+= -iquote $(obj)/
 
diff --git a/images/fdinfo.proto b/images/fdinfo.proto
index 32ec13cf4..a84055e3a 100644
--- a/images/fdinfo.proto
+++ b/images/fdinfo.proto
@@ -21,6 +21,7 @@ import "pidfd.proto";
 import "tty.proto";
 import "memfd.proto";
 import "bpfmap-file.proto";
+import "posix-mqueue.proto";
 
 enum fd_types {
 	UND		= 0;
@@ -44,6 +45,7 @@ enum fd_types {
 	MEMFD		= 18;
 	BPFMAP		= 19;
 	PIDFD           = 20;
+	PQEFD		= 21;
 
 	/* Any number above the real used. Not stored to image */
 	CTL_TTY		= 65534;
@@ -81,4 +83,5 @@ message file_entry {
 	optional memfd_file_entry	memfd	= 20;
 	optional bpfmap_file_entry	bpf	= 21;
 	optional pidfd_entry		pidfd   = 22;
+	optional ipcns_pmq_data_entry pqmfd = 23;
 }
diff --git a/images/posix-mqueue.proto b/images/posix-mqueue.proto
new file mode 100644
index 000000000..a7bff10d2
--- /dev/null
+++ b/images/posix-mqueue.proto
@@ -0,0 +1,23 @@
+syntax = "proto2";
+
+import "fown.proto";
+
+message posix_mqueue_msg_entry {
+    required uint32 msg_prio = 1;
+    required uint32 msg_len  = 2;
+    required bytes  msg_data = 3;
+}
+
+message ipcns_pmq_data_entry {
+    required uint32 id          = 1;
+    required string name        = 2;
+
+    required uint32 mq_maxmsg   = 3;
+    required uint32 mq_msgsize  = 4;
+    required uint32 mq_curmsgs  = 5;
+
+    repeated posix_mqueue_msg_entry messages = 6;
+
+    required uint32    flags = 7;
+    required fown_entry fown = 8;
+}
\ No newline at end of file
