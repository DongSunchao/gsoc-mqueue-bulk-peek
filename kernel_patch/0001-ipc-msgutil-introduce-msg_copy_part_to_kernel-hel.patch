From afa4b3832c77d26f7df6b0a5e55a5f83f9bb88d9 Mon Sep 17 00:00:00 2001
From: dong sunchao <dongsunchao@gmail.com>
Date: Tue, 17 Mar 2026 19:36:57 +1100
Subject: [PATCH 1/3] ipc/msgutil: introduce msg_copy_part_to_kernel helper

Introduce msg_copy_part_to_kernel() to safely extract a byte range from a
msg_msg across msg_msgseg boundaries. This encapsulates the internal memory
layout and avoids out-of-bounds reads or uninitialized data exposure.

EXPORT_SYMBOL_GPL is provided to allow reuse across IPC users when built as
modules.

Signed-off-by: dong sunchao <dongsunchao@gmail.com>
---
 include/linux/msg.h |  3 +++
 ipc/msgutil.c       | 47 +++++++++++++++++++++++++++++++++++++++++++++
 2 files changed, 50 insertions(+)

diff --git a/include/linux/msg.h b/include/linux/msg.h
index 9a972a296b953..6196b630fa4bc 100644
--- a/include/linux/msg.h
+++ b/include/linux/msg.h
@@ -15,4 +15,7 @@ struct msg_msg {
 	/* the actual message follows immediately */
 };
 
+void msg_copy_part_to_kernel(struct msg_msg *msg, u8 *dest,
+			     size_t skip_bytes, size_t copy_bytes);
+
 #endif /* _LINUX_MSG_H */
diff --git a/ipc/msgutil.c b/ipc/msgutil.c
index e28f0cecb2ec9..654a7b67c6423 100644
--- a/ipc/msgutil.c
+++ b/ipc/msgutil.c
@@ -190,3 +190,50 @@ void free_msg(struct msg_msg *msg)
 		seg = tmp;
 	}
 }
+
+void msg_copy_part_to_kernel(struct msg_msg *msg, u8 *dest,
+			     size_t skip_bytes, size_t copy_bytes)
+{
+	struct msg_msgseg *seg;
+	size_t seg_len, chunk;
+	u8 *src;
+	size_t real_remain = msg->m_ts;
+
+	if (WARN_ON_ONCE(skip_bytes + copy_bytes > msg->m_ts))
+		return;
+
+	/* First chunk is inline in struct msg_msg */
+	seg_len = min_t(size_t, real_remain, DATALEN_MSG);
+	src = (u8 *)(msg + 1);
+
+	if (skip_bytes < seg_len) {
+		chunk = min_t(size_t, copy_bytes, seg_len - skip_bytes);
+		memcpy(dest, src + skip_bytes, chunk);
+		dest += chunk;
+		copy_bytes -= chunk;
+		skip_bytes = 0;
+	} else {
+		skip_bytes -= seg_len;
+	}
+
+	real_remain -= seg_len;
+
+	/* Subsequent chunks are in msg_msgseg chains */
+	for (seg = msg->next; seg && copy_bytes > 0; seg = seg->next) {
+		seg_len = min_t(size_t, real_remain, DATALEN_SEG);
+
+		src = (u8 *)(seg + 1);
+
+		if (skip_bytes < seg_len) {
+			chunk = min_t(size_t, copy_bytes, seg_len - skip_bytes);
+			memcpy(dest, src + skip_bytes, chunk);
+			dest += chunk;
+			copy_bytes -= chunk;
+			skip_bytes = 0;
+		} else {
+			skip_bytes -= seg_len;
+		}
+		real_remain -= seg_len;
+	}
+}
+EXPORT_SYMBOL_GPL(msg_copy_part_to_kernel);
-- 
